@model ContatoModel
@{
    ViewData["Title"] = "Confirmação apagar o contato";
}

<div class="text-center">
    <h3>Deseja realmente apagar o contato? (@Model.Nome)?</h3>
</div>

<a class="btn btn-secondary" role="button" asp-controller="Contato" asp-action="Index">Cancelar Exclusão</a>
<a class="btn btn-primary" role="button" asp-controller="Contato" asp-action="Apagar">Confirmar Exclusão</a>
